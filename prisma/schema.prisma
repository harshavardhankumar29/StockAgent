// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ResearchHistory {
  id                String   @id @default(uuid())
  userId            String
  companyName       String
  ticker            String
  decision          String
  confidenceScore   Int
  reasoning         String
  keyMetrics        String   // stored as JSON string
  bullPoints        String   // stored as JSON string
  bearPoints        String   // stored as JSON string
  financialHealth   String?
  moatStrength      String?
  growthProspects   String?
  riskLevel         String?
  timeHorizon       String?
  chartData         String?  // stored as JSON string of 90-day prices
  competitorMetrics String?  // stored as JSON string of competitor financials
  critique          String?  // stored as text
  uploadedContextId String?  // link to uploaded context document/image summary
  createdAt         DateTime @default(now())

  @@index([userId])
}

model UploadedContext {
  id          String   @id @default(uuid())
  userId      String
  fileName    String
  fileType    String   // "PDF" or "IMAGE"
  parsedText  String   // raw parsed text or visual summary
  createdAt   DateTime @default(now())

  @@index([userId])
}


model Watchlist {
  id          String   @id @default(uuid())
  userId      String
  ticker      String
  companyName String
  createdAt   DateTime @default(now())

  @@unique([userId, ticker])
}

model PortfolioTransaction {
  id          String   @id @default(uuid())
  userId      String
  ticker      String
  companyName String
  type        String   // "BUY" or "SELL"
  shares      Float
  price       Float
  createdAt   DateTime @default(now())

  @@index([userId])
}

